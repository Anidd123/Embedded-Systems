// Code for alternate LED blinking

#define led1 14
#define led2 19

void setup() {
  // put your setup code here, to run once:
  pinMode(led1, OUTPUT);
  pinMode(led2, OUTPUT);
}

void loop() {
  // put your main code here, to run repeatedly:
  digitalWrite(led1, 1);
  digitalWrite(led2, 0);
  delay(1000);
  digitalWrite(led1, 0);
  digitalWrite(led2, 1);
  delay(1000);
}
